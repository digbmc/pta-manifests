ations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11857/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11857/canvas/1/98e1cbd4-3a4e-4bd2-8948-bd7a531c6f37","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:49:28.650Z","creator":"lucia","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>The camera is positioned so that the viewer feels they are watching Alma and Reynolds through the doorframe, as if watching but attempting not to intrude. As she cares for him, Alma creates an intimate, isolated space for the two of them, shutting all others out as she nurses him. The camera reflects this, as even the viewer is not given full or close access to them in this shot.&nbsp;&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11857/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:96.59311562224187,85.84289496910853,277.91703442188884,162.6831421006178"}}}]}]}]}