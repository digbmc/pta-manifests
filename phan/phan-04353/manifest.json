r.edu/pta/phan/phan-04353/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04353/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04353/canvas/1/09c48be4-9416-4b13-90cb-7cc886987e08","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T20:02:04.697Z","creator":"g","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Trent Ludwig proposes a psychoanalytic reading of <em>Phantom Thread</em> that situates “the dress” as the film’s most important object and sign: “each dress is also a repetition of Reynolds’ mother’s wedding dress that holds a transformational power to affect a becoming-mother in the dress wearer” (Ludwig, “Threading Between Dresses and Debts,” 165). In other words, the dress as a concept brings together the film’s economic, social, artistic, romantic, and familial themes.&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04353/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:608.5598923283984,264.1453566621804,629.2328398384926,713.2166890982505"}}}]}]}]}