            },
            {
              "id": "https://digitalscholarship.brynmawr.edu/pta/phan/phan-01942/canvas/1/5bb58270-e4f2-4aa9-97c6-fc1672a331ac",
              "type": "Annotation",
              "motivation": "commenting",
              "body": [
                {
                  "created": "2026-07-17T18:58:27.818Z",
                  "creator": "lucia",
                  "purpose": "commenting",
                  "type": "TextualBody",
                  "format": "text/html",
                  "value": "<p><a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW54546407 BCX2\" href=\"https://humanehollywood.org/production/phantom-thread/\"><u>According to the Hollywood Humane program</u></a>, the film received full certification from the <a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW54546407 BCX2\" href=\"https://www.americanhumane.org/\"><u>American Humane Society</u></a>. They share that “[t]he dogs were transported and kept in the trainers van in custom-built cages.&nbsp; Each cage had a water bowl and soft bed. The dogs were taken out for regular toilet breaks and short walks.”&nbsp;</p>"
                }
              ],
