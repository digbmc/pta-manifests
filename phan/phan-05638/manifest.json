r.edu/pta/phan/phan-05638/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05638/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05638/canvas/1/a27f6d28-83a4-4a74-8e9b-c8c7717674f0","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:48:52.569Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Although Alma and Reynolds find themselves in a period of peaceful co-existence and, as much as possible for the “confirmed bachelor,” love, the black teapot stands between them on the table. It’s a reminder of the power struggle that they are, ultimately, locked in, and in this shot, Reynolds’s and Cyril’s hands stand in the foreground, emphasizing the triangular tension that exists between these characters.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05638/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:752.9329128440367,240.25587729357798,1025.5045871559632,667.6655676605506"}}}]}]}]}