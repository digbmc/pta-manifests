Phantom Thread</u></a>”).&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00832/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:784.3181818181819,153.77272727272714,414.1363636363634,584.5113636363635"}}}]}]}]}