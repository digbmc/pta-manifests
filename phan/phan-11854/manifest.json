ions":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11854/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11854/canvas/1/7924a9e2-8ea7-4af8-8421-c4540e9ac3e2","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:48:09.950Z","creator":"lucia","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Alma puts down the window shade for Reynolds, like a mother putting her child down for a nap. His illness renders him incredibly childlike, which we can see from his positioning on the bed. Curled up, covering his face, he appears open and vulnerable, in need of (Alma’s) care. With his bent legs, he is trying to make himself smaller, as if he were returning to a childish state.&nbsp;&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-11854/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:564.307149161518,582.3654015887025,701.5710503089144,385.52515445719325"}}}]}]}]}