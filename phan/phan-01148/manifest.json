{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://digbmc.github.io/pta-manifests/phan/phan-01148/manifest.json","type":"Manifest","label":{"none":["PHAN-01148"]},"metadata":[{"label":{"none":["Timestamp"]},"value":{"none":["0:11:48"]}},{"label":{"none":["Film"]},"value":{"none":["Phantom Thread"]}},{"label":{"none":["Creator"]},"value":{"none":["Paul Thomas Anderson"]}},{"label":{"none":["Distance"]},"value":{"none":["full shot"]}},{"label":{"none":["Angle"]},"value":{"none":["low"]}},{"label":{"none":["Location"]},"value":{"none":["exterior"]}},{"label":{"none":["Movement"]},"value":{"none":["fixed"]}},{"label":{"none":["Composition"]},"value":{"none":["single shot"]}}],"summary":{"none":["A man steps out of his car."]},"thumbnail":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/tiles/full/300,169/0/default.jpg","type":"Image","format":"image/jpeg","height":169,"width":300}],"homepage":[{"id":"PHAN-01148","type":"Text","format":"text/html","label":{"none":["Object homepage"]}}],"items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1","type":"Canvas","height":1080,"width":1920,"label":{"none":["PHAN-01148"]},"thumbnail":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/tiles/full/300,169/0/default.jpg","type":"Image","format":"image/jpeg","height":169,"width":300}],"items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1/annopage-1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1/annopage-1/anno-1","type":"Annotation","motivation":"painting","target":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1","body":{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/tiles/full/1920,1080/0/default.jpg","type":"Image","format":"image/jpeg","height":1080,"width":1920,"service":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1/57dc47e4-8313-41f8-a1c5-d733bbd2c274","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T19:38:27.788Z","creator":"Clara Smith","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p><em>Phantom Thread</em> was PTA’s first film produced without a credited cinematographer. According to the director, the cinematography was ultimately a collaboration between himself, lighting cameraman Michael Bauman, key grip Jeff Kunkel, first assistant cameraman Erik Brown, and camera operator Colin Anderson, with whom PTA had worked on smaller projects, such as music videos (Davis, “<a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW45532967 BCX0\" href=\"https://www.fandango.com/movie-news/paul-thomas-anderson-talks-phantom-thread-and-how-punch-drunk-love-changed-his-filmmaking-forever-752884\"><u>Paul Thomas Anderson Talks</u></a>”). Members of this group spoke about this atypical collaboration in these two <a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW45532967 BCX0\" href=\"https://www.youtube.com/watch?v=kpi393XkzUo\"><u>video</u></a> <a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW45532967 BCX0\" href=\"https://www.youtube.com/watch?v=zpgyq9VhOIA\"><u>streams</u></a>. For an analysis of this process and the lens tests that the team ran, see In Depth Cine’s “<a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW45532967 BCX0\" href=\"https://www.youtube.com/watch?v=8dmxrBwbseI\"><em><u>A Film With No Cinematographer: Phantom Thread,</u></em></a>.”</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-01148/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:12.470802919708,48.613138686131414,291.580291970803,159.09854014598542"}}}]}]}]}