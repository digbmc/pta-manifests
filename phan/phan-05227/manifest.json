rvice":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05227/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05227/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05227/canvas/1/8fffe8d6-0e28-4445-8e10-fa2f3292353d","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T20:21:17.586Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Rubio kisses Barbara, distracting her from her anger at the reporter, because the reporters had asked them to. We never see the couple express physical affection at any other point. Their relationship seems entirely performative, with no true love between them. The real-life Rubio, Porfirio Rubirosa, captured Barbara Hutton’s attention by gathering friends to serenade her with musical accompaniment beneath her window (Haymann, <em>Poor Little Rich Girl</em>, 288).</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05227/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:315.83028907242664,293.56496188055866,999.4143106734434,506.18448221092757"}}}]}]}]}