rynmawr.edu/pta/phan/phan-05728/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05728/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05728/canvas/1/980fa8e1-27a7-4e96-b024-9c24d74f8874","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:59:00.515Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>A small Belgium flag adorns the front of Princess Mona Braganza’s car. It thus contrasts with the British flag on Reynolds’s house. One possible reading of <em>Phantom Thread</em> concerns the clash between English culture and a foreign, continental European one (in the form of Alma). The postwar context of the film and the memories of an “invasion” give this interpretation a darker undertone.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05728/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:935.2809633027524,655.0480217889909,105.73322821100908,78.36295871559639"}}}]}]}]}