mageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00156/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00156/canvas/1/57252a7a-4ba7-4fb1-9e03-399487a8ae96","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T14:11:23.854Z","creator":"Clara Smith","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p><em>Phantom Thread</em> is PTA’s first film set and shot entirely abroad. PTA shot this film primarily in North Yorkshire and London. With the exception of a few scenes in <em>The Master,</em> the rest of his films have taken place in the U.S., particularly southern California. When asked about this shift, PTA replied that the subject of the film (high fashion in the 1950s) limited his choices to London and Paris, but he had also always wanted to work in England and to collaborate with English actors (Xixax TV, “<a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW49143581 BCX0\" href=\"https://www.youtube.com/watch?v=4Y0X0KLWy4k\"><u>PHANTOM THREAD - Q&amp;A</u></a>”).&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00156/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:10.456204379562095,38.57299270072993,254.16788321167877,166.20437956204375"}}}]}]}]}