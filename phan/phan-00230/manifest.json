":1080,"width":1920,"service":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1/2af04312-04f3-42dd-b57d-72d88e0e39a9","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T14:30:58.965Z","creator":"Clara Smith","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>The staff at the House of Woodcock enter via an entrance on the lower level of a house, as was typical of servants and employees in London at that time.&nbsp;&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:1327.8284671532847,328.0620437956204,489.0328467153288,708.2299270072992"}}},{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1/c4a1a07e-8f0f-471b-9b43-3d76c1ee68a5","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T14:31:14.666Z","creator":"Clara Smith","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>The dark, dreary street contrasts with the bright and luminous interior of the House of Woodcock, a contrast that the editing between this shot and the next makes especially poignant.&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:760.029197080292,218.50729927007302,453.7992700729927,513.9963503649635"}}},{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-00230/canvas/1/dab62283-cd1a-4317-a5f8