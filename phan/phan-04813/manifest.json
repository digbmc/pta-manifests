scholarship.brynmawr.edu/pta/phan/phan-04813/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04813/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04813/canvas/1/82c5ac88-71f5-463f-bd0f-ac8d75deb051","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T19:13:02.779Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Tellingly, this scene includes Reynolds, but the opening shots include only Alma and Cyril. The wordless shot-reverse shot establishes them as the primary interlocutors at this point in the film. On the one hand,&nbsp;this moment seems to suggest that Cyril has shifted allegiances. On the other hand, they may be dueling with smiles and knowing glances.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-04813/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:595.3346565731179,123.42872968980754,1186.3390878877399,759.4165435745938"}}}]}]}]}