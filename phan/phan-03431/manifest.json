an/phan-03431/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-03431/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-03431/canvas/1/8285ae04-667c-4d75-a05c-a0de2599c7e5","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:33:26.274Z","creator":"g","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>While one might expect the couple to consummate their relationship, <em>Phantom Thread</em> resists the overt sexual energies that once drove PTA’s work in <em>Boogie Nights</em>. Instead, as the next scenes will demonstrate, that passion and energy is channeled into dressmaking for Reynolds, work that Alma is more than willing to support. For the moment, she is left frustrated, but in the visual language of the film, she and Reynolds will engage in their own brand of lovemaking in a moment.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-03431/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:711.4563106796116,192.0388349514563,605.8252427184465,553.009708737864"}}}]}]}]}