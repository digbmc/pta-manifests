/phan-05009/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05009/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05009/canvas/1/dbd83a75-7e1a-458b-8e43-b3e13ae86b7c","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T19:45:02.137Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>By taking off the necklace, Barbara Rose is removing a visual signifier of her wealth and laying herself bare to Reynolds, who has shown himself to be unconcerned with financial repute as opposed to respect and status. Whereas <a target=\"_blank\" rel=\"noreferrer noopener\" class=\"Hyperlink SCXW156068440 BCX0\" href=\"https://ptannotated.com/items/phan-00649.html\"><u>Henrietta was being dressed up</u></a>, Barbara Rose is being dressed down.&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05009/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:762.2359675036928,634.251984859675,355.1352474150665,405.52344903988194"}}}]}]}]}