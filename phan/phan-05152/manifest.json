brynmawr.edu/pta/phan/phan-05152/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05152/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05152/canvas/1/477d3ef1-b820-47af-b386-1df9cf1a7a1e","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T19:58:55.950Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Rubio Gurrerro is based on Barbara Hutton’s fifth husband, Dominican diplomat and playboy Porfirio Rubirosa, who was “raised and educated in Paris, attending the finest schools and early in life circulating among the highest ranks of society” (Haymann, <em>Poor Little Rich Girl</em>, 286). Porfirio was as well known for his taste for the extravagant as for his “prodigal dimensions,” which, allegedly, inspired the use of his surname for requesting freshly ground pepper “in the finest European restaurants” (Haymann, <em>Poor Little Rich Girl</em>, 289). Their marriage lasted 53 days.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05152/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:183.9930299113736,276.35616691285077,537.8563515509602,497.46353397341215"}}}]}]}]}