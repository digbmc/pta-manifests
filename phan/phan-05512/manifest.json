u/pta/phan/phan-05512/tiles","type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05512/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05512/canvas/1/180b0706-b640-452f-85f4-49b95c27e119","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:01:39.064Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>The camera switches to handheld to echo Barbara Rose’s drunken stupor.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05512/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:27.338335292851497,27.131251946816732,234.37500000000003,190.77551605504595"}}},{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05512/canvas/1/133bac86-8422-4c7b-b51a-7e121a989597","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-30T14:02:00.463Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>By positioning Alma above Barbara Rose as she undresses her, the camera asserts Alma’s power over the woman. Although Barbara Rose is their client, whose patronage Cyril says is very financially important, in this moment Reynolds (through Alma) refuses to defer to her. Alma takes back power for Reynolds by determining is Barbara unworthy to wear their fashions.&nbsp;</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05512/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:623.3962481368882,118.66651570828466,771.7961582568811,445.44868119266073"}}}]}]}]}