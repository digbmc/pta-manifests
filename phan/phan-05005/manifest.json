"type":"ImageService3","profile":"http://iiif.io/api/image/3/level0.json"}]}}]}],"annotations":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05005/canvas/1/page/p1","type":"AnnotationPage","items":[{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05005/canvas/1/dc028244-0bff-4f28-a83a-fc7cdcb29391","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T19:41:53.803Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Barbara Rose’s shoulders are naked, showing her vulnerability as a woman falling apart.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05005/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:617.1720365583457,612.2484305760709,1012.7492614475626,317.6899464549483"}}},{"id":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05005/canvas/1/2c6a3ac2-68ec-45d3-97d0-35dc6e34a512","type":"Annotation","motivation":"commenting","body":[{"created":"2026-06-29T19:42:18.554Z","creator":"Tallulah Stallvik","purpose":"commenting","type":"TextualBody","format":"text/html","value":"<p>Barbara Rose struggles to clasp her necklace, then drops it into her handbag gracelessly. The clumsy way Barbara handles her—presumably very expensive—jewelry speaks to her lack of appreciation for the fine things she owns. This is Reynolds’s main struggle with her. While she has the money to buy expensive things, like his dresses, she&nbsp;does not have the refinement to understand and appreciate their artistry.</p>"}],"target":{"type":"SpecificResource","source":"https://digitalscholarship.brynmawr.edu/pta/phan/phan-05005/canvas/1","selector":{"type":"FragmentSelector","conformsTo":"http://www.w3.org/TR/media-frags/","value":"xywh=pixel:934.1328932791728,710.3764309453471,251.87246122599709,183.0139863367799"}}}]}]}]}